{%- liquid
  assign base_url = block.settings.app_url_override | strip
  if base_url == blank
    assign base_url = app.metafields.configurator_app_url.value | strip
  endif
  assign configurator_url = ''
  if base_url != blank and product
    assign configurator_url = base_url | append: '/configurator/' | append: product.id | append: '?shop=' | append: shop.permanent_domain
  endif
-%}

{%- if product == blank -%}
  {%- if request.design_mode -%}
  <div style="padding:14px 16px;border:2px dashed #f59e0b;border-radius:8px;background:#fffbeb;font-family:sans-serif;">
    <p style="margin:0;font-size:13px;font-weight:600;color:#92400e;">⚠️ Theme editor only — Wrong section</p>
    <p style="margin:4px 0 0;font-size:12px;color:#78350f;">This block must be placed inside a <strong>Product page</strong> section, not a general page.</p>
  </div>
  {%- endif -%}
{%- elsif product.tags contains 'configurator-enabled' -%}
  {%- if configurator_url == blank -%}
  {%- if request.design_mode -%}
  <div style="padding:14px 16px;border:2px dashed #ef4444;border-radius:8px;background:#fef2f2;font-family:sans-serif;">
    <p style="margin:0;font-size:13px;font-weight:600;color:#991b1b;">⚠️ Development only — App URL not detected</p>
    <p style="margin:4px 0 0;font-size:12px;color:#7f1d1d;">If testing locally, paste your ngrok URL in the <strong>Dev URL Override</strong> field below.<br>In production this resolves automatically — no action needed.</p>
  </div>
  {%- endif -%}
  {%- else -%}

<div id="product-configurator-{{ product.id }}" data-url="{{ configurator_url }}">

  <!-- ── Button & Modal Styles ──────────────────────────────────── -->
  <style>
    /* ─── Customize Button ─── */
    #open-configurator-{{ product.id }} {
      --cf-btn-bg:    {{ block.settings.button_color }};
      --cf-btn-color: {{ block.settings.button_text_color }};

      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      {% if block.settings.full_width %}width: 100%;{% endif %}
      padding: 14px 28px;
      box-sizing: border-box;

      /* Colors from block settings — merchant overrides via theme editor */
      background: var(--cf-btn-bg);
      color: var(--cf-btn-color);

      /* Border — inherit width/opacity from theme (OS2.0 vars), colour from our text colour */
      border-style: solid;
      border-width: var(--buttons-border-width, 0px);
      border-color: rgba(255, 255, 255, var(--buttons-border-opacity, 0));
      border-radius: var(--buttons-radius-outset, var(--buttons-radius, 8px));

      /* Typography — inherit theme font family; keep our own size/weight */
      font-family: var(--font-body-family, var(--font-heading-family, inherit));
      font-style:  var(--font-body-style, normal);
      font-size:   15px;
      font-weight: 600;
      letter-spacing: 0.025em;
      line-height: 1;
      text-decoration: none;

      cursor: pointer;
      transition: opacity 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
      -webkit-appearance: none;
      appearance: none;
    }

    #open-configurator-{{ product.id }}:hover {
      opacity: 0.87;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
    }

    #open-configurator-{{ product.id }}:active {
      transform: translateY(0);
      opacity: 0.95;
      box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);
    }

    #open-configurator-{{ product.id }}:focus-visible {
      outline: 2px solid var(--cf-btn-bg);
      outline-offset: 3px;
    }

    /* Loading state — aria-busy prevents interaction & shows spinner */
    #open-configurator-{{ product.id }}[aria-busy="true"] {
      opacity: 0.72;
      pointer-events: none;
      cursor: wait;
    }

    /* Icon / spinner swap */
    .cf-btn-icon-{{ product.id }}    { display: flex; align-items: center; flex-shrink: 0; }
    .cf-btn-spinner-{{ product.id }} { display: none; flex-shrink: 0; }

    #open-configurator-{{ product.id }}[aria-busy="true"] .cf-btn-icon-{{ product.id }} { display: none; }
    #open-configurator-{{ product.id }}[aria-busy="true"] .cf-btn-spinner-{{ product.id }} {
      display: block;
      width: 15px;
      height: 15px;
      border: 2px solid rgba(255, 255, 255, 0.35);
      border-top-color: currentColor;
      border-radius: 50%;
      animation: cf-spin-{{ product.id }} 0.65s linear infinite;
    }

    @keyframes cf-spin-{{ product.id }} { to { transform: rotate(360deg); } }

    /* ─── Modal Animations ─── */
    @keyframes cf-overlay-in-{{ product.id }} {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes cf-modal-in-{{ product.id }} {
      from { opacity: 0; transform: scale(0.96) translateY(12px); }
      to   { opacity: 1; transform: scale(1)    translateY(0);    }
    }

    #configurator-modal-{{ product.id }}.cf-open {
      animation: cf-overlay-in-{{ product.id }} 0.18s ease forwards;
    }
    #configurator-modal-{{ product.id }}.cf-open .cf-modal-box {
      animation: cf-modal-in-{{ product.id }} 0.26s cubic-bezier(0.34, 1.4, 0.64, 1) forwards;
    }

    @media (max-width: 600px) {
      #configurator-modal-{{ product.id }} .cf-modal-box {
        width: 100vw !important;
        height: 100dvh !important;
        border-radius: 0 !important;
        max-width: 100vw !important;
      }
    }
  </style>

  <!-- ── Customize Button ──────────────────────────────────────── -->
  <button
    id="open-configurator-{{ product.id }}"
    type="button"
    aria-haspopup="dialog"
    aria-label="{{ block.settings.button_text }}"
  >
    <span class="cf-btn-icon-{{ product.id }}" aria-hidden="true">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20h9"/>
        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
    </span>
    <span class="cf-btn-spinner-{{ product.id }}" aria-hidden="true"></span>
    {{ block.settings.button_text }}
  </button>

  <!-- ── Modal Overlay ─────────────────────────────────────────── -->
  <div
    id="configurator-modal-{{ product.id }}"
    role="dialog"
    aria-modal="true"
    aria-label="{{ block.settings.button_text }}"
    style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.65); backdrop-filter:blur(6px); -webkit-backdrop-filter:blur(6px); align-items:center; justify-content:center;"
  >
    <div
      class="cf-modal-box"
      style="position:relative; width:min(1280px,98vw); height:min(900px,84vh); background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 32px 80px rgba(0,0,0,0.4),0 8px 32px rgba(0,0,0,0.15); display:flex; flex-direction:column;"
    >
      <iframe
        id="configurator-iframe-{{ product.id }}"
        src="about:blank"
        data-src="{{ configurator_url }}"
        style="flex:1; min-height:0; border:none; display:block; width:100%;"
        title="Product Configurator"
        allow="clipboard-write"
      ></iframe>
    </div>
  </div>

</div>

<script>
(function () {
  var productId = '{{ product.id }}';
  var configUrl = '{{ configurator_url }}';
  var hideATC   = {{ block.settings.hide_buy_buttons | json }};

  var openBtn = document.getElementById('open-configurator-'   + productId);
  var modal   = document.getElementById('configurator-modal-'  + productId);
  var iframe  = document.getElementById('configurator-iframe-' + productId);

  if (!openBtn || !modal) return;

  if (hideATC) {
    ['.product-form__buttons', '.shopify-payment-button', '.product-form [type="submit"]',
     'form[action="/cart/add"] .btn', 'form[action="/cart/add"] button[type="submit"]']
      .forEach(function (sel) {
        document.querySelectorAll(sel).forEach(function (el) { el.style.display = 'none'; });
      });
  }

  function getVariantId() {
    var form = document.querySelector('form[action*="/cart/add"]');
    if (form) {
      var input = form.querySelector('input[name="id"]');
      if (input && input.value) return parseInt(input.value, 10);
    }
    return {{ product.selected_or_first_available_variant.id | default: 0 }};
  }

  function setLoading(on) {
    if (on) {
      openBtn.setAttribute('aria-busy', 'true');
    } else {
      openBtn.removeAttribute('aria-busy');
    }
  }

  function openModal() {
    setLoading(true);
    if (!iframe.src || iframe.src === 'about:blank' || iframe.src === window.location.href) {
      iframe.src = configUrl;
    }
    modal.style.display = 'flex';
    requestAnimationFrame(function () { modal.classList.add('cf-open'); });
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('cf-open');
    modal.style.display = 'none';
    document.body.style.overflow = '';
    setLoading(false);
  }

  /* Remove spinner once iframe content is fully loaded */
  iframe.addEventListener('load', function () { setLoading(false); });

  openBtn.addEventListener('click', openModal);
  modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && modal.style.display !== 'none') closeModal(); });

  window.addEventListener('message', function (event) {
    if (!event.data) return;
    if (event.data.type === 'configurator:close')  { closeModal();      return; }
    if (event.data.type === 'configurator:ready')  { setLoading(false); return; }
    if (event.data.type !== 'configurator:add-to-cart') return;

    var properties = event.data.properties || {};
    var variantId  = getVariantId();

    if (!variantId) { console.error('Configurator: no variant ID'); return; }

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1, properties: properties }] })
    })
      .then(function (res) {
        return res.ok ? res.json() : res.json().then(function (e) { throw new Error(e.description || 'Could not add to cart'); });
      })
      .then(function () {
        closeModal();
        window.location.href = '/cart?_=' + Date.now();
      })
      .catch(function (err) { alert(err.message); });
  });
})();
</script>

  {%- endif -%}
{%- else -%}
  {%- if request.design_mode -%}
  <div style="padding:14px 16px;border:2px dashed #6366f1;border-radius:8px;background:#eef2ff;font-family:sans-serif;">
    <p style="margin:0;font-size:13px;font-weight:600;color:#3730a3;">ℹ️ Product not configured yet</p>
    <p style="margin:4px 0 0;font-size:12px;color:#4338ca;">Open the <strong>Product Configurator</strong> app, select this product, build its configurator and click <strong>Save</strong>. The Customize button will appear automatically once it's set up.</p>
  </div>
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Product Configurator",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Label",
      "default": "Customize This Product"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Colour",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Colour",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full-width Button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hide_buy_buttons",
      "label": "Hide standard Add to Cart & Buy it now",
      "info": "Enable this for products that must be customized before purchase.",
      "default": true
    },
    {
      "type": "text",
      "id": "app_url_override",
      "label": "Dev URL Override (optional)",
      "info": "Leave blank in production — the URL is set automatically. Only needed when testing locally with ngrok (e.g. https://xxxx.ngrok-free.app)."
    }
  ]
}
{% endschema %}
